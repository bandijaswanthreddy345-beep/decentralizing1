# ─── Deployer Wallet ─────────────────────────────────────────────────────────
# Private key of the wallet used to deploy contracts
# NEVER commit the real .env — this is a template only
PRIVATE_KEY=your_wallet_private_key_here

# ─── Polygon Amoy Testnet (blockchain/.env — used by Hardhat deploy) ─────────
# RPC endpoint for Polygon Amoy testnet
# Get a free key from: https://www.alchemy.com or https://www.infura.io
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_api_key_here

# ─── Deployed Contract ────────────────────────────────────────────────────────
# Address of the deployed RoomRegistry contract
# Auto-populated in deployments.json after running the deploy script
# Copy this value into BOTH blockchain/.env AND backend/.env
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
