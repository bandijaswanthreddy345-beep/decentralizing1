# ─── Existing backend variables (already configured) ─────────────────────────
PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key

# ─── Blockchain integration (add these to your existing backend .env) ─────────

# RPC URL the backend uses to read/write the contract
# Local dev:  http://127.0.0.1:8545  (Hardhat node)
# Testnet:    same as POLYGON_RPC_URL in blockchain/.env
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Private key of the backend signer wallet (same as blockchain/.env PRIVATE_KEY)
# This wallet pays gas for createRoom / transferOwnership transactions
PRIVATE_KEY=your_wallet_private_key_here

# Deployed RoomRegistry contract address (from deployments.json after deploy)
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
